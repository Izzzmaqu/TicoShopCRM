@model TicoShopCRM.Models.Caso

@{
    ViewData["Title"] = "Detalle Caso";
}

<h1>Detalle Caso</h1>

<div>
    <dl class="row">
        <dt class="col-sm-3">Cliente</dt>
        <dd class="col-sm-9">@Model.Cliente?.Nombre</dd>

        <dt class="col-sm-3">Título</dt>
        <dd class="col-sm-9">@Model.Titulo</dd>

        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@Model.Descripcion</dd>

        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">@Model.Estado</dd>

        <dt class="col-sm-3">Fecha Creación</dt>
        <dd class="col-sm-9">@Model.FechaCreacion.ToString("g")</dd>

        <dt class="col-sm-3">Fecha Resolución</dt>
        <dd class="col-sm-9">@(Model.FechaResolucion?.ToString("g") ?? "Pendiente")</dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>