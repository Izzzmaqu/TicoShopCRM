@model TicoShopCRM.Models.Campana

@{
    ViewData["Title"] = "Eliminar Campaña";
}

<h1>Eliminar Campaña</h1>

<h3>¿Seguro que deseas eliminar esta campaña?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>

        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">@Model.Estado</dd>

        <dt class="col-sm-3">Presupuesto</dt>
        <dd class="col-sm-9">₡@Model.Presupuesto.ToString("N2")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>