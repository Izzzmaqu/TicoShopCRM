@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center">
    <h1 class="display-4">Bienvenido a TicoShopCRM</h1>
    <p class="lead">Sistema básico de gestión para clientes, productos, campañas y casos.</p>
</div>

<div class="row mt-4">
    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Clientes</h5>
                <p class="card-text">Administra tus clientes registrados.</p>
                <a asp-controller="Clientes" asp-action="Index" class="btn btn-primary">Ir a Clientes</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Productos</h5>
                <p class="card-text">Consulta y registra productos.</p>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-primary">Ir a Productos</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Campañas</h5>
                <p class="card-text">Gestiona campañas comerciales.</p>
                <a asp-controller="Campanas" asp-action="Index" class="btn btn-primary">Ir a Campañas</a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Casos</h5>
                <p class="card-text">Da seguimiento a incidencias y casos.</p>
                <a asp-controller="Casos" asp-action="Index" class="btn btn-primary">Ir a Casos</a>
            </div>
        </div>
    </div>
</div>